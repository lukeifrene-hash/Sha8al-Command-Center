# Preferred public setup for Sha8al Command Center (`sha8al-command-center`): generate a fresh env file instead of editing this template by hand.
# npm run bootstrap -- --project /absolute/path/to/project
# Optional preview: npm run bootstrap -- --project /absolute/path/to/project --output-env-file /tmp/command-center.env
# After bootstrap:
# npm run tracker:guard:status
# Public parser aliases resolve scripts/parse-markdown.mjs --profile=generic.
# Keep COMMAND_CENTER_PROFILE=generic for public installs; the compatibility parser aliases are separate.
# npm run tracker:parse:project-tasks:dry-run
# npm run tracker:parse:project-tasks

# Manual fallback for a fresh external install:
COMMAND_CENTER_PROFILE=generic

# Required: path to the target project repo that owns the tracker + docs
COMMAND_CENTER_PROJECT_ROOT=/path/to/project

# Required public task source: docs/roadmap.md feeds the swim lane and task board.
# Optional file-path overrides if your project does not use the default public layout:
# COMMAND_CENTER_TRACKER_FILE=command-center-tracker.json
# COMMAND_CENTER_TASKS_DOC=docs/roadmap.md
# COMMAND_CENTER_CHECKLIST_DOC=docs/submission-checklist.md
# COMMAND_CENTER_MANIFESTO_DOC=docs/manifesto.md

# Tracker writes stay guarded when the target resolves to the live sibling TalkStore tracker.
# Set this only for an intentional compatibility write:
# COMMAND_CENTER_ALLOW_TRACKER_WRITES=true

# Existing TalkStore installs can still opt into compatibility mode:
# COMMAND_CENTER_PROFILE=talkstore
# TALKSTORE_PROJECT_ROOT=/path/to/talkstore
# COMMAND_CENTER_TRACKER_FILE=talkstore-tracker.json
# These compatibility alias names hit the TalkStore parser profile explicitly.
# npm run tracker:parse:talkstore-tasks:dry-run
# COMMAND_CENTER_TASKS_DOC=docs/tasks.md
# COMMAND_CENTER_CHECKLIST_DOC=docs/submission-checklist.md

# Other workflow-specific override:
# COMMAND_CENTER_ACI_ROADMAP=Brainstorming & Pivot/ROADMAP.md
