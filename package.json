{
  "name": "sha8al-command-center",
  "version": "1.0.0",
  "private": true,
  "productName": "Sha8al Command Center",
  "description": "Sha8al Command Center (sha8al-command-center) platform repo for tracker-driven project orchestration, with TalkStore compatibility support",
  "main": "./out/main/index.js",
  "scripts": {
    "bootstrap": "node scripts/bootstrap.mjs",
    "postinstall": "bash scripts/patch-electron.sh",
    "check:docs-completeness": "node scripts/check-docs-completeness.mjs",
    "check:example-readiness": "node scripts/check-example-readiness.mjs",
    "check:public-identity": "node scripts/check-public-identity.mjs",
    "check:profile-resolution": "node scripts/check-profile-resolution.mjs",
    "check:parser-profile-mismatch": "node scripts/check-parser-profile-mismatch.mjs",
    "check:backup-behavior": "node scripts/check-backup-behavior.mjs",
    "check:external-example-bootstrap": "node scripts/check-external-example-bootstrap.mjs",
    "check:bootstrap-scaffold": "node scripts/check-bootstrap-scaffold.mjs",
    "check:bootstrap-path": "node scripts/check-external-example-bootstrap.mjs",
    "check:public-repo-readiness": "node scripts/check-public-repo-readiness.mjs",
    "check:validation": "npm run check:profile-resolution && npm run check:parser-profile-mismatch && npm run check:backup-behavior && npm run check:external-example-bootstrap && npm run check:bootstrap-scaffold",
    "check:publish-readiness": "node scripts/check-publish-readiness.mjs",
    "playbook:check": "node scripts/check-playbook-sync.mjs",
    "tracker:guard:status": "node scripts/tracker-guard-status.mjs",
    "tracker:parse:project-tasks": "node scripts/parse-markdown.mjs --consumer-profile=generic --profile=generic --tasks-source=docs/roadmap.md",
    "tracker:parse:project-tasks:dry-run": "node scripts/parse-markdown.mjs --consumer-profile=generic --profile=generic --tasks-source=docs/roadmap.md --dry-run",
    "tracker:parse:legacy-roadmap": "node scripts/parse-markdown.mjs --consumer-profile=generic --profile=generic --tasks-source=docs/roadmap.md",
    "tracker:parse:legacy-roadmap:dry-run": "node scripts/parse-markdown.mjs --consumer-profile=generic --profile=generic --tasks-source=docs/roadmap.md --dry-run",
    "tracker:parse:talkstore-tasks": "node scripts/parse-markdown.mjs --consumer-profile=talkstore --profile=talkstore --tasks-source=docs/tasks.md --checklist-source=docs/submission-checklist.md",
    "tracker:parse:talkstore-tasks:dry-run": "node scripts/parse-markdown.mjs --consumer-profile=talkstore --profile=talkstore --tasks-source=docs/tasks.md --checklist-source=docs/submission-checklist.md --dry-run",
    "tracker:parse:talkstore-roadmap": "node scripts/parse-markdown.mjs --consumer-profile=talkstore --profile=talkstore --tasks-source=docs/roadmap.md --checklist-source=docs/submission-checklist.md",
    "tracker:parse:talkstore-roadmap:dry-run": "node scripts/parse-markdown.mjs --consumer-profile=talkstore --profile=talkstore --tasks-source=docs/roadmap.md --checklist-source=docs/submission-checklist.md --dry-run",
    "tracker:parse:aci-roadmap": "node scripts/parse-aci-roadmap.mjs --profile=aci --aci-roadmap-source=\"Brainstorming & Pivot/ROADMAP.md\"",
    "tracker:parse:aci-roadmap:dry-run": "node scripts/parse-aci-roadmap.mjs --profile=aci --aci-roadmap-source=\"Brainstorming & Pivot/ROADMAP.md\" --dry-run",
    "tracker:seed:aci": "node scripts/seed-aci-checklist.mjs --profile=aci",
    "tracker:seed:aci:dry-run": "node scripts/seed-aci-checklist.mjs --profile=aci --dry-run",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview"
  },
  "keywords": [
    "sha8al-command-center",
    "sha8al",
    "command-center",
    "electron",
    "mcp",
    "tracker",
    "project-orchestration",
    "talkstore-compatibility"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@tailwindcss/postcss": "^4.2.1",
    "@vitejs/plugin-react": "^5.1.4",
    "electron-vite": "^5.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite": "^7.3.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "electron": "^41.0.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  }
}
